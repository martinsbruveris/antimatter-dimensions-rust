{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Antimatter Dimensions",
  "version": "0.1.0",
  "identifier": "com.antimatter-dimensions.rust",
  "build": {
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "./frontend/dist"
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Antimatter Dimensions",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
